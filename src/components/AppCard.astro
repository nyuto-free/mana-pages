---
import type { AppMeta } from '../data/apps';
import DeviceBadges from './DeviceBadges.astro';

interface Props {
  app: AppMeta;
}

const { app } = Astro.props;

const statusLabel: Record<typeof app.status, string> = {
  available: 'App Store 配信中',
  review: 'App Store 審査中',
  'coming-soon': '近日公開',
};
---

<a class="app-card" href={`/apps/${app.slug}`} style={`--card-accent: ${app.accentColor};`}>
  <span class="card-glow" aria-hidden="true"></span>
  <div class="icon-wrap">
    <span class="icon-halo" aria-hidden="true"></span>
    <div class="icon">
      <img src={app.iconImage} alt={`${app.name} アプリアイコン`} width="104" height="104" />
    </div>
  </div>
  <div class="body">
    <p class="status">{statusLabel[app.status]}</p>
    <h3>{app.name}</h3>
    <p class="tagline">{app.tagline}</p>
    <p class="muted small">{app.description}</p>
    <div class="badge-row"><DeviceBadges devices={app.devices} /></div>
    <span class="more">詳しく見る →</span>
  </div>
</a>

<style>
  .app-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 22px;
    padding: 40px 32px 32px;
    background: linear-gradient(180deg, rgba(10, 11, 14, 0.85) 0%, rgba(6, 7, 8, 0.85) 100%);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.3s ease;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(8px);
    height: 100%;
  }

  .card-glow {
    position: absolute;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    background: radial-gradient(closest-side, var(--card-accent, var(--color-indigo)), transparent 70%);
    opacity: 0.16;
    filter: blur(90px);
    top: -140px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.5s ease;
  }

  .app-card:hover {
    transform: translateY(-4px);
    border-color: rgba(124, 141, 255, 0.4);
    box-shadow: var(--glow-ring), var(--shadow-md);
    color: var(--color-text);
  }

  .app-card:hover .card-glow {
    opacity: 0.3;
    transform: translate(-50%, 20px) scale(1.08);
  }

  .icon-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-halo {
    position: absolute;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: radial-gradient(closest-side, var(--card-accent, var(--color-indigo)), transparent 70%);
    filter: blur(40px);
    opacity: 0.45;
    pointer-events: none;
  }

  .icon {
    position: relative;
    width: 104px;
    height: 104px;
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06),
      0 18px 44px rgba(0, 0, 0, 0.5);
  }

  .icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .icon::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), transparent 35%);
    pointer-events: none;
  }

  .body {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    z-index: 1;
    width: 100%;
  }

  .status {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--card-accent, var(--color-indigo));
    font-weight: 700;
    margin: 0;
  }

  h3 {
    font-size: 1.65rem;
    margin: 4px 0 2px;
  }

  .tagline {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--color-text);
    margin: 0 0 10px;
    opacity: 0.95;
  }

  .small {
    font-size: 0.92rem;
    margin: 0 0 14px;
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 32ch;
  }

  .badge-row {
    display: flex;
    justify-content: center;
    margin: 0 0 14px;
  }

  .more {
    margin-top: auto;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-indigo);
    letter-spacing: 0.04em;
  }

  @media (max-width: 560px) {
    .app-card {
      padding: 32px 24px 28px;
      gap: 18px;
    }
    .icon {
      width: 88px;
      height: 88px;
      border-radius: 20px;
    }
    .icon-halo {
      width: 140px;
      height: 140px;
    }
    h3 {
      font-size: 1.4rem;
    }
  }
</style>
