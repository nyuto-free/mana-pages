---
import type { Device } from '../data/apps';

interface Props {
  devices: Device[];
  size?: 'sm' | 'md';
}

const { devices, size = 'sm' } = Astro.props;

const labels: Record<Device, string> = {
  iphone: 'iPhone',
  ipad: 'iPad',
  mac: 'Mac',
};
---

<ul class={`device-badges ${size}`} aria-label="対応デバイス">
  {devices.map((device) => (
    <li class="device-badge" title={labels[device]}>
      {device === 'iphone' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="7" y="2.5" width="10" height="19" rx="2.2"></rect>
          <line x1="11" y1="18.6" x2="13" y2="18.6"></line>
        </svg>
      )}
      {device === 'ipad' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="4" y="2.5" width="16" height="19" rx="2"></rect>
          <line x1="11" y1="19" x2="13" y2="19"></line>
        </svg>
      )}
      {device === 'mac' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="12" rx="1.6"></rect>
          <line x1="2" y1="19.5" x2="22" y2="19.5"></line>
        </svg>
      )}
      <span class="label">{labels[device]}</span>
    </li>
  ))}
</ul>

<style>
  .device-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .device-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px 5px 9px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .device-badge:hover {
    color: var(--color-text);
    border-color: rgba(124, 141, 255, 0.35);
    background: rgba(124, 141, 255, 0.06);
  }

  .device-badge svg {
    width: 13px;
    height: 13px;
    opacity: 0.9;
  }

  .md .device-badge {
    padding: 7px 14px 7px 11px;
    font-size: 0.85rem;
    gap: 8px;
  }

  .md .device-badge svg {
    width: 15px;
    height: 15px;
  }
</style>
