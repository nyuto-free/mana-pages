---
const links = [
  { href: '/#apps', label: 'アプリ' },
  { href: '/#about', label: 'シリーズについて' },
  { href: 'mailto:support@mana-app.studio', label: 'お問い合わせ' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-name">Mana</span>
    </a>
    <nav>
      <ul>
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: linear-gradient(180deg, rgba(3, 3, 5, 0.65) 0%, rgba(3, 3, 5, 0) 100%);
    backdrop-filter: saturate(150%) blur(14px);
    -webkit-backdrop-filter: saturate(150%) blur(14px);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--color-text);
    font-weight: 700;
  }

  .brand:hover {
    color: var(--color-text);
  }

  .brand-mark {
    width: 28px;
    height: 28px;
    border-radius: 9px;
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.18), transparent 60%),
      linear-gradient(135deg, var(--color-indigo) 0%, var(--color-gold) 100%);
    box-shadow: 0 0 0 1px rgba(124, 141, 255, 0.3),
      0 6px 18px rgba(124, 141, 255, 0.35);
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    letter-spacing: 0.06em;
  }

  nav ul {
    display: flex;
    gap: 30px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav a {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    font-weight: 500;
    transition: color 0.15s ease;
  }

  nav a:hover {
    color: var(--color-text);
  }

  @media (max-width: 560px) {
    nav ul {
      gap: 18px;
    }
    nav a {
      font-size: 0.85rem;
    }
  }
</style>
